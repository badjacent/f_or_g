# Optional. Leave blank if feed access does not require a key.
MTA_API_KEY=

# GTFS-RT endpoints used together for F or G coverage.
MTA_FEED_URLS=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-bdfm,https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-g

# Boarding stop IDs wired for your brooklyn-bound flow:
# F board at Jay St-MetroTech (A41S); G board at Hoyt-Schermerhorn Sts (A42S)
MTA_BOARDING_STOP_IDS_F=A41S
MTA_BOARDING_STOP_IDS_G=A42S
# Destination context
MTA_DESTINATION_STOP_ID=F21S

MAX_FEED_AGE_SECONDS=60
TIE_WINDOW_SECONDS=60
FEED_CACHE_SECONDS=20
